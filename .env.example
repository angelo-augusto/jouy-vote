# Copier en .env et renseigner une vraie clé avant de lancer le conteneur.
# Clé OpenRouter dédiée à ce projet — à ne PAS confondre avec celle du RPG (mj/.env),
# pour garder la facturation/l'usage séparés par projet.
OPENROUTER_API_KEY=

# Variables nécessaires pour FAIRE TOURNER l'application elle-même (main.py) — le serveur
# refuse de démarrer si l'une des deux est absente, aucune valeur par défaut utilisable.
# JOUY_ADMIN_KEY : clé pour créer/désactiver des questions (POST /questions, PATCH /questions/{id}).
JOUY_ADMIN_KEY=
# JOUY_VOTE_PEPPER : secret serveur qui dérive vote_token à partir du jeton d'inscription
# (sha256(token+pepper)) — garantit qu'un JOIN direct identities.token=votes.vote_token est
# impossible sans connaître ce secret, même avec un accès complet à la base.
JOUY_VOTE_PEPPER=

# Identifiants du compte admin DokuWiki (wiki.jouyvote.fr), utilisés une seule fois par le
# script d'installation (Playwright) qui remplit l'assistant de premier démarrage de DokuWiki
# — l'image officielle n'a pas de variables d'env pour ça. Angelo change le mot de passe une
# fois connecté, ces valeurs ne servent qu'au provisioning initial.
WIKI_ADMIN_USER=
WIKI_ADMIN_PASSWORD=
